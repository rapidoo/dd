# ---------- LLM provider ----------
# anthropic (défaut, prod Vercel) | ollama (dev local avec Gemma 3)
LLM_PROVIDER=anthropic

# Anthropic : requis si LLM_PROVIDER=anthropic (sinon ignoré)
ANTHROPIC_API_KEY=

# Ollama : URL du serveur local (uniquement si LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Overrides de modèle (optionnels). Si vide, défauts selon LLM_PROVIDER :
#   anthropic → tout en claude-haiku-4-5
#   ollama    → builder=gemma4:31b, gm=gemma4:26b, companion=gemma4:e4b, util=gemma4:e2b
#
# À pull avant le premier run en mode Ollama :
#   ollama pull gemma4:31b gemma4:26b gemma4:e4b gemma4:e2b
#
# Si un modèle ne supporte pas les tools, le serveur renvoie une erreur
# explicite "model_no_tool_support" avec un hint — override LLM_MODEL_GM
# vers un modèle tool-capable au besoin.
LLM_MODEL_BUILDER=
LLM_MODEL_GM=
LLM_MODEL_COMPANION=
LLM_MODEL_UTIL=

# ---------- Supabase ----------
# URL + clés du projet Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: server-only, ne jamais exposer au client
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Neo4j AuraDB ----------
# Mémoire de campagne (graphe)
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# ---------- Runtime ----------
# URL publique de l'app (pour magic link redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
