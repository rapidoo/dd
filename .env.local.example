# ---------- Anthropic ----------
# Clé API unique pour MJ (Opus 4.7), compagnons (Sonnet 4.5), utilitaires (Haiku 4.5)
ANTHROPIC_API_KEY=

# ---------- Supabase ----------
# URL + clés du projet Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: server-only, ne jamais exposer au client
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Neo4j AuraDB ----------
# Mémoire de campagne (graphe)
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# ---------- Runtime ----------
# URL publique de l'app (pour magic link redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
